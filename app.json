{
  "expo": {
    "name": "Dapto",
    "slug": "doctor-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/daptao.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/daptao.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.singhaditya1627.doctormobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Allow access to camera to send photos in chat.",
        "NSPhotoLibraryUsageDescription": "Allow access to your photos to send images in chat.",
        "NSPhotoLibraryAddUsageDescription": "Allow saving images to your library."
      }
    },
    "android": {
      "usesCleartextTraffic": true,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./assets/daptao.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.singhaditya1627.doctormobile"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-notifications"
    ],
    "extra": {
      "apiUrl": "http://103.205.140.228/api",
      "socketUrl": "http://103.205.140.228",
      "eas": {
        "projectId": "bc39d0b4-2a38-42dc-9400-21b7bbc216a1"
      }
    },
    "owner": "harshittripathi22"
  }
}
