{
  "expo": {
    "name": "Dapto",
    "slug": "Dapto",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/daptao.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/daptao.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.singhaditya1627.dapto",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Allow access to camera to send photos in chat.",
        "NSPhotoLibraryUsageDescription": "Allow access to your photos to send images in chat.",
        "NSPhotoLibraryAddUsageDescription": "Allow saving images to your library."
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "usesCleartextTraffic": false,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ],
      "blockedPermissions": [
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.RECORD_AUDIO",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./assets/daptao.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.singhaditya1627.dapto"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-notifications"
    ],
    "extra": {
      "apiUrl": "https://dapto.vinfocom.co.in/api",
      "socketUrl": "https://dapto.vinfocom.co.in",
      "eas": {
        "projectId": "1db0ddb0-7155-4300-a308-38afad0ddf76"
      }
    },
    "owner": "singhaditya1627"
  }
}
